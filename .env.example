# Admin panel password
VITE_ADMIN_PASSWORD=evomi2026

# PostgreSQL (wajib) — install di Windows ATAU paste URL dari Railway
# Lokal: postgresql://evomi:evomi@localhost:5432/evomi (lihat docs/LOCAL-DATABASE.md)
DATABASE_URL=postgresql://evomi:evomi@localhost:5432/evomi

# API server port
PORT=3001

# Folder upload gambar (opsional)
# Lokal: kosongkan → default public/uploads
# Railway volume: mount volume ke /data, lalu:
# UPLOAD_PUBLIC_DIR=/data/uploads
UPLOAD_PUBLIC_DIR=

# Halaman /official — tampilkan situs kedua, URL browser tetap evomi.id/official
OFFICIAL_SITE_URL=https://evomoy.netlify.app

# Railway: WAJIB — DATABASE_URL = Reference ke service PostgreSQL (bukan DB baru tiap deploy)
# Lihat docs/PERSISTENCE.md jika data hilang setelah redeploy
#
# Build: npm run build | Start: npm start (Express + API + dist)
