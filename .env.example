# Admin panel password
VITE_ADMIN_PASSWORD=evomi2026

# PostgreSQL (wajib untuk menyimpan konten & waitlist)
DATABASE_URL=postgresql://evomi:evomi@localhost:5432/evomi

# API server port
PORT=3001

# Folder upload gambar (opsional)
# Lokal: kosongkan → default public/uploads
# Railway volume: mount volume ke /data, lalu:
# UPLOAD_PUBLIC_DIR=/data/uploads
UPLOAD_PUBLIC_DIR=

# Railway: link variable DATABASE_URL dari service PostgreSQL (wajib)
# Build: npm run build | Start: npm start (Express + API + dist)
